# ---------------------------------------------------------------------------
# TAMS deployment configuration TEMPLATE (11 §5). Copy to deploy/.env and fill
# in per environment. In real environments these values come from a secret
# store / the platform's env injection — NEVER commit a filled-in .env.
# deploy/.env is gitignored.
#
#   cp deploy/.env.example deploy/.env   # then edit
# ---------------------------------------------------------------------------

# Image tag to build/run (promote the SAME tag Dev->...->Prod, DP-02).
TAMS_TAG=latest

# --- Database ---
# SA password for the bundled SQL Server (dev/staging convenience). In production,
# SQL Server is externally managed with TDE + backups and this is not used.
MSSQL_SA_PASSWORD=CHANGE_ME_strong_password

# App connection string. Use a LEAST-PRIVILEGE application principal (SELECT/
# INSERT/UPDATE + INSERT/SELECT on audit only) — NOT sa, NOT the DDL migration
# principal (06 §5, 04 §13). TrustServerCertificate only where TLS to SQL is not
# yet configured; prefer Encrypt=true with a trusted cert in production.
TAMS_DB_CONNECTION=Server=db;Database=TAMS;User Id=tams_app;Password=CHANGE_ME;TrustServerCertificate=true

# --- JWT (06 §6) ---
# MUST be >= 32 bytes or the app fails fast at startup (P6 ValidateOnStart).
# Generate a random one, e.g.:  openssl rand -base64 48
TAMS_JWT_SIGNING_KEY=CHANGE_ME_at_least_32_bytes_random_secret
TAMS_JWT_ISSUER=TAMS
TAMS_JWT_AUDIENCE=TAMS.Client

# --- Edge / CORS / hosts ---
# The public origin the SPA is served from (the API CORS allow-list; the SPA
# itself is same-origin so this mainly covers non-browser API clients).
TAMS_SPA_ORIGIN=https://tams.example.com
# Host header allow-list (defence-in-depth; replace the dev '*').
TAMS_ALLOWED_HOSTS=tams.example.com
# Host directory holding tams.crt / tams.key for the proxy (mounted read-only).
TAMS_TLS_CERT_DIR=./certs

# --- Worker ---
TAMS_WORKER_POLL_SECONDS=30
