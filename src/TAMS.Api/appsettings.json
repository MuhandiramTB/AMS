{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "TAMS",
    "Audience": "TAMS.Client",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "LockoutMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Seed": {
    "Enabled": false
  }
}
