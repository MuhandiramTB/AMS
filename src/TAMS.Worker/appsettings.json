{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Jwt": {
    "Issuer": "TAMS",
    "Audience": "TAMS.Client",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "LockoutMinutes": 15
  },
  "Worker": {
    "PollIntervalSeconds": 30,
    "UnreachableAlertThreshold": 3
  }
}
